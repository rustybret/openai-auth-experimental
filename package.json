{
  "name": "@cortexkit/openai-auth",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "cd packages/opencode && bun run build",
    "dev": "bun scripts/dev.ts",
    "dev:clean": "bun scripts/dev-clean.ts",
    "test": "cd packages/opencode && bun run test",
    "typecheck": "cd packages/opencode && bun run typecheck",
    "types": "bun run typecheck",
    "format": "biome check --write --unsafe .",
    "format:check": "biome format .",
    "lint": "biome lint .",
    "pack:opencode:dry": "cd packages/opencode && bun pm pack --dry-run",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@opencode-ai/plugin": "1.17.1",
    "@tsconfig/bun": "1.0.10",
    "@types/bun": "1.3.14",
    "bun-types": "1.3.14",
    "lefthook": "2.1.9",
    "typescript": "6.0.3"
  }
}
